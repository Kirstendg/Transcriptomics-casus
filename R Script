# Statistische analyses uitvoeren

# Tabel maken met overzicht zieke en gezonde mensen
Behandeling <- c("Normaal", "Normaal", "Normaal", "Normaal", "Ziek", "Ziek", "Ziek", "Ziek")
Behandeling_tabel <- data.frame(Behandeling = Behandeling)
colnames(Behandeling_tabel) <- c('nor1', 'nor2', 'nor3', 'nor4', 'ziek1', 'ziek2', 'ziek3', 'ziek4')
rownames(Behandeling_tabel) <- colnames(CM)

# Maak DESeqDataSet aan
dds <- DESeqDataSetFromMatrix(countData = round(CM),
                                colData = Behandeling_tabel,
                                design = ~ Behandeling)

# Voer analyse uit
dds <- DESeq(dds)
resultaten <- results(dds)

# Resultaten opslaan in een bestand
