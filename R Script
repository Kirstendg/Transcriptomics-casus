  )

# GO analyse

# Karaktervector met alle gen ID's
alle_gen_ids <- rownames(resultaten)

# Karatervector met DE gen ID's
de_gen_ids <- row.names(resultaten)[which(!is.na(resultaten$padj) & resultaten$padj < 0.05)]

# Maak gene.vector
gene.vector=as.integer(alle_gen_ids%in%de_gen_ids)
names(gene.vector)=alle_gen_ids

# Vector bekijken
head(gene.vector)
tail(gene.vector)

# Bereken nulwaarde 
pwf <- nullp(gene.vector, "hg19", "geneSymbol")

# GO Enrichment test (overrepesentatie)
GO_wall <- goseq(pwf, genome = "hg19", id = "geneSymbol", test.cats = c("GO:BP","GO:MF","GO:CC"))

# Resultaten filteren en p-waarde correctie
GO_wall$padj <- p.adjust(GO_wall$over_represented_pvalue, method = "BH")

# De top 10 van de GO analyse plotten
GO_wall %>% top_n(10, wt = -over_represented_pvalue) %>% 
  mutate(hitsPerc = numDEInCat * 100 / numInCat) %>%
  ggplot(aes(x = hitsPerc, y = term, colour = over_represented_pvalue
             , size = numDEInCat)) +
  geom_point() + expand_limits(x = 25) + 
  labs(x = "Hits (%)", y = "GO term", colour = "p value", size = "Count")
