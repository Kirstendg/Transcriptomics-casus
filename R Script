# Vector maken met namen en BAM bestanden
samples <- c("uitgepakte_casus_data/Data_RA_raw/nor1.BAM" , "uitgepakte_casus_data/Data_RA_raw/nor2.BAM", 
             "uitgepakte_casus_data/Data_RA_raw/nor3.BAM", "uitgepakte_casus_data/Data_RA_raw/nor4.BAM", 
             "uitgepakte_casus_data/Data_RA_raw/ziek1.BAM", "uitgepakte_casus_data/Data_RA_raw/ziek2.BAM", 
             "uitgepakte_casus_data/Data_RA_raw/ziek3.BAM", "uitgepakte_casus_data/Data_RA_raw/ziek4.BAM")

# Count matrix maken
count_matrix <- featureCounts(
  files = samples,
  annot.ext = "uitgepakte_casus_data/ncbi_humaan_GTF/ncbi_dataset/data/GCF_000001405.40/genomic.gtf",
  isPairedEnd = TRUE,
  isGTFAnnotationFile = TRUE,
  GTF.attrType = "gene_id",
  useMetaFeatures = TRUE)

# Count matrix inladen
read.table("C:/Users/kirst/OneDrive - Van Hall Larenstein/J2P4 Moderne DNA-technologiën/Transcriptomics/count_matrix.txt")
CM <- read.table ("C:/Users/kirst/OneDrive - Van Hall Larenstein/J2P4 Moderne DNA-technologiën/Transcriptomics/count_matrix.txt") 

# Tabel maken met overzicht zieke en gezonde mensen
Behandeling <- c("Normaal", "Normaal", "Normaal", "Normaal", "Ziek", "Ziek", "Ziek", "Ziek")
Behandeling_tabel <- data.frame(Behandeling = Behandeling)
colnames(Behandeling_tabel) <- c('nor1', 'nor2', 'nor3', 'nor4', 'ziek1', 'ziek2', 'ziek3', 'ziek4')
rownames(Behandeling_tabel) <- colnames(CM)

# Benodigde packages voor genexpressie aanzetten
library(DESeq2)
library(KEGGREST)

# Maak DESeqDataSet aan
  dds <- DESeqDataSetFromMatrix(countData = round(CM),
                                colData = Behandeling_tabel,
                                design = ~ Behandeling)

# Voer analyse uit
dds <- DESeq(dds)
resultaten <- results(dds)

# Resultaten opslaan in een bestand
# Bij het opslaan van je tabel kan je opnieuw je pad instellen met `setwd()` of het gehele pad waar je de tabel wilt opslaan opgeven in de code.

write.table(resultaten, file = ("C:/Users/kirst/OneDrive - Van Hall Larenstein/J2P4 Moderne DNA-technologiën/Transcriptomics/'resultaten.csv'"), row.names = TRUE, col.names = TRUE)

# Bepalen hoeveel genen er daadwerkelijk veranderen, dit met significantie
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange > 1, na.rm = TRUE)
sum(resultaten$padj < 0.05 & resultaten$log2FoldChange < -1, na.rm = TRUE)

# Sorteren van resultaat naar opvallendste genen
hoogste_fold_change <- resultaten[order(resultaten$log2FoldChange, decreasing = TRUE), ]
laagste_fold_change <- resultaten[order(resultaten$log2FoldChange, decreasing = FALSE), ]
laagste_p_waarde <- resultaten[order(resultaten$padj, decreasing = FALSE), ]

# Genen die het belangrijkst zijn volgens de analyse
head(laagste_p_waarde)

